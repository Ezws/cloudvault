# CloudVault Server Configuration Example
# Copy this file to .env and modify the values

# Database (PostgreSQL)
CV__DATABASE__URL=postgres://cloudvault:password@localhost:5432/cloudvault

# Server
CV__SERVER__HOST=0.0.0.0
CV__SERVER__PORT=8080

# JWT Authentication
CV__JWT__SECRET=your-secret-key-change-in-production
CV__JWT__EXPIRATION_HOURS=24

# Storage
CV__STORAGE__LOCAL_PATH=./storage